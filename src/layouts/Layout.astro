---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Estudio Jurídico Integral Rozas - Molina & Asociados. Experiencia, firmeza y respaldo legal." } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="antialiased flex flex-col min-h-screen selection:bg-brand-gold selection:text-brand-dark">
    
    <header id="main-header" class="fixed w-full top-0 z-50 bg-transparent border-b border-transparent transition-all duration-500 py-6">
      <div class="container mx-auto px-6 md:px-10 flex justify-between items-center">
        
        <a href="#inicio" class="flex flex-col group z-50">
          <span class="text-[8px] md:text-[9px] font-body text-brand-gold tracking-[0.4em] uppercase font-semibold mb-1 opacity-80 group-hover:opacity-100 transition-opacity">Estudio Jurídico</span>
          <h1 id="logo-text" class="text-2xl md:text-3xl font-heading font-semibold text-white transition-colors duration-500 leading-none tracking-wide">
            ROZAS<span class="font-light italic text-brand-gold mx-1.5">&</span>MOLINA
          </h1>
        </a>
        
        <div class="hidden lg:flex items-center gap-10">
          <nav>
            <ul id="nav-links" class="flex items-center gap-10 text-[11px] font-body font-medium tracking-[0.25em] text-white transition-colors duration-500 uppercase">
              <li>
                <a href="#areas" class="flex items-center gap-2 group hover:text-brand-gold transition-colors duration-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-gold opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
                  Práctica
                </a>
              </li>
              <li>
                <a href="#estudio" class="flex items-center gap-2 group hover:text-brand-gold transition-colors duration-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-gold opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
                  La Firma
                </a>
              </li>
            </ul>
          </nav>

          <div id="nav-divider" class="w-px h-8 bg-white/20 transition-colors duration-500"></div>

          <a id="nav-btn" href="#contacto" class="inline-flex items-center justify-center border border-white text-white px-8 py-3.5 font-body text-[10px] uppercase tracking-[0.25em] hover:bg-white hover:text-brand-dark transition-all duration-500">
            Consulta Privada
          </a>
        </div>

        <button id="mobile-menu-btn" class="lg:hidden z-50 relative focus:outline-none w-10 h-10 flex flex-col justify-center items-end gap-1.5 group" aria-label="Abrir Menú">
          <span class="w-7 h-px bg-white transition-colors duration-300 origin-center" id="line1"></span>
          <span class="w-5 h-px bg-brand-gold transition-colors duration-300 origin-center group-hover:w-7" id="line2"></span>
          <span class="w-7 h-px bg-white transition-colors duration-300 origin-center" id="line3"></span>
        </button>
      </div>
    </header>

    <div id="mobile-menu" class="fixed inset-0 bg-brand-dark/98 backdrop-blur-2xl opacity-0 pointer-events-none transition-opacity duration-500 z-45 flex flex-col pt-36 pb-12 overflow-y-auto">
      <div class="container mx-auto px-8 w-full flex flex-col h-full grow">
        <nav class="flex flex-col gap-8 w-full mt-4">
          <a href="#areas" class="mobile-link group flex items-center gap-6 border-b border-white/10 pb-6 translate-y-8 opacity-0 transition-all duration-500 delay-100">
            <span class="text-brand-gold font-body text-xs tracking-widest opacity-50">01</span>
            <span class="text-3xl font-heading font-light text-white group-hover:text-brand-gold transition-colors">Práctica</span>
          </a>
          <a href="#estudio" class="mobile-link group flex items-center gap-6 border-b border-white/10 pb-6 translate-y-8 opacity-0 transition-all duration-500 delay-200">
            <span class="text-brand-gold font-body text-xs tracking-widest opacity-50">02</span>
            <span class="text-3xl font-heading font-light text-white group-hover:text-brand-gold transition-colors">La Firma</span>
          </a>
          <a href="#contacto" class="mobile-link group flex items-center gap-6 border-b border-white/10 pb-6 translate-y-8 opacity-0 transition-all duration-500 delay-300">
            <span class="text-brand-gold font-body text-xs tracking-widest opacity-50">03</span>
            <span class="text-3xl font-heading font-light text-white group-hover:text-brand-gold transition-colors">Contacto</span>
          </a>
        </nav>
      </div>
    </div>

    <main class="grow">
      <slot />
    </main>

    <footer class="bg-brand-dark text-gray-400 pt-16 pb-12 border-t border-brand-gold/20 relative z-20">
      <div class="container mx-auto px-6 md:px-8 grid grid-cols-1 md:grid-cols-12 gap-16 lg:gap-12 mb-20">
        
        <div class="md:col-span-12 lg:col-span-5">
          <h2 class="text-3xl font-heading font-semibold text-white leading-none tracking-wide mb-6">
            ROZAS <span class="font-light italic text-brand-gold">&</span> MOLINA
          </h2>
          <p class="text-sm font-light leading-loose max-w-sm text-gray-400 mb-8">
            Asesoría jurídica de excelencia. Defendemos sus intereses con la firmeza, discreción y la estrategia que los asuntos complejos exigen.
          </p>
          <a href="https://wa.me/5491100000000" class="inline-flex items-center gap-3 text-brand-gold hover:text-white transition-colors font-body text-xs tracking-widest uppercase">
            <span class="w-8 h-px bg-brand-gold"></span>
            Línea Directa
          </a>
        </div>

        <div class="md:col-span-6 lg:col-span-3">
          <span class="text-white uppercase tracking-[0.2em] text-[10px] font-bold mb-8 block">Especialidades</span>
          <ul class="space-y-4 text-sm font-light text-gray-400">
            <li>Defensas Penales</li>
            <li>Sucesiones y Divorcios</li>
            <li>Conflictos Laborales</li>
            <li>Asuntos Tributarios</li>
          </ul>
        </div>

        <div class="md:col-span-6 lg:col-span-4">
          <span class="text-white uppercase tracking-[0.2em] text-[10px] font-bold mb-8 block">Sede</span>
          <ul class="space-y-4 text-sm font-light text-gray-400">
            <li>Alejandro Korn, Buenos Aires</li>
            <li>Atención presencial con cita previa.</li>
            <li class="pt-4"><a href="mailto:contacto@rozasmolina.com" class="hover:text-brand-gold transition-colors">contacto@rozasmolina.com</a></li>
          </ul>
        </div>
      </div>

      <div class="container mx-auto px-6 md:px-8 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] uppercase tracking-[0.2em] font-body text-gray-600">
        <p>© {new Date().getFullYear()} Rozas Molina.</p>
        <div class="flex items-center gap-2">
          <span>Design by</span>
          <a href="#" class="text-brand-gold hover:text-white transition-colors">VisionPath</a>
        </div>
      </div>
    </footer>

    <a href="https://wa.me/5491100000000" target="_blank" aria-label="Contactar por WhatsApp" class="fixed bottom-6 right-6 md:bottom-8 md:right-8 z-50 bg-brand-gold text-brand-dark p-4 rounded-full shadow-2xl hover:scale-105 hover:bg-white transition-all duration-500 flex items-center justify-center border border-brand-dark/10">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-whatsapp relative z-10" viewBox="0 0 16 16"><path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/></svg>
    </a>

    <script>
      import Lenis from 'lenis';
      const lenis = new Lenis({ duration: 1.5, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
      function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);

      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const header = document.getElementById('main-header');
      const mobileLinks = document.querySelectorAll('.mobile-link');
      
      const logoText = document.getElementById('logo-text');
      const navLinks = document.getElementById('nav-links');
      const navDivider = document.getElementById('nav-divider');
      const navBtn = document.getElementById('nav-btn');
      const line1 = document.getElementById('line1');
      const line2 = document.getElementById('line2');
      const line3 = document.getElementById('line3');

      let isScrolled = false;
      let isMenuOpen = false;

      const closeMenu = () => {
        isMenuOpen = false;
        menu?.classList.remove('opacity-100', 'pointer-events-auto');
        menu?.classList.add('opacity-0', 'pointer-events-none');
        
        const targetLineColor = isScrolled ? 'bg-brand-dark' : 'bg-white';
        line1?.classList.replace('bg-brand-gold', targetLineColor);
        line3?.classList.replace('bg-brand-gold', targetLineColor);
        
        line1?.classList.remove('rotate-45', 'translate-y-[7px]');
        line2?.classList.remove('opacity-0');
        line3?.classList.remove('-rotate-45', '-translate-y-[7px]');
        
        mobileLinks.forEach(link => {
          link.classList.remove('translate-y-0', 'opacity-100');
          link.classList.add('translate-y-8', 'opacity-0');
        });
        
        // Si cerramos el menú y estábamos scrolleados, devolvemos el header a "Modo Blanco"
        if (isScrolled) {
            header?.classList.replace('bg-transparent', 'bg-white/95');
            header?.classList.replace('border-transparent', 'border-gray-100');
            header?.classList.add('backdrop-blur-xl', 'shadow-sm');
            logoText?.classList.replace('text-white', 'text-brand-dark');
        }
        lenis.start();
      };

      const openMenu = () => {
        isMenuOpen = true;
        menu?.classList.remove('opacity-0', 'pointer-events-none');
        menu?.classList.add('opacity-100', 'pointer-events-auto');
        
        const currentLineColor = isScrolled ? 'bg-brand-dark' : 'bg-white';
        line1?.classList.replace(currentLineColor, 'bg-brand-gold');
        line3?.classList.replace(currentLineColor, 'bg-brand-gold');
        
        line1?.classList.add('rotate-45', 'translate-y-[7px]');
        line2?.classList.add('opacity-0');
        line3?.classList.add('-rotate-45', '-translate-y-[7px]');
        
        mobileLinks.forEach(link => {
          link.classList.remove('translate-y-8', 'opacity-0');
          link.classList.add('translate-y-0', 'opacity-100');
        });
        
        // Si abrimos el menú estando scrolleados, forzamos el logo a blanco y ocultamos el fondo blanco del header
        if (isScrolled) {
            header?.classList.replace('bg-white/95', 'bg-transparent');
            header?.classList.replace('border-gray-100', 'border-transparent');
            header?.classList.remove('backdrop-blur-xl', 'shadow-sm');
            logoText?.classList.replace('text-brand-dark', 'text-white');
        }
        lenis.stop();
      };

      btn?.addEventListener('click', () => isMenuOpen ? closeMenu() : openMenu());

      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault();
          const target = e.currentTarget as HTMLElement;
          const targetId = target.getAttribute('href');
          if (!targetId || targetId === '#') return;
          const targetElement = document.querySelector(targetId) as HTMLElement;
          if (targetElement) {
            if (target.classList.contains('mobile-link') || target.closest('#mobile-menu')) {
              closeMenu();
              setTimeout(() => lenis.scrollTo(targetElement, { offset: -100, duration: 2 }), 300);
            } else {
              lenis.scrollTo(targetElement, { offset: -100, duration: 2 });
            }
          }
        });
      });

      lenis.on('scroll', (e: any) => {
        if (!isMenuOpen) {
          if (e.scroll > 50 && !isScrolled) {
            isScrolled = true;
            header?.classList.replace('bg-transparent', 'bg-white/95');
            header?.classList.replace('border-transparent', 'border-gray-100');
            header?.classList.add('backdrop-blur-xl', 'shadow-sm');
            header?.classList.replace('py-6', 'py-4');

            logoText?.classList.replace('text-white', 'text-brand-dark');
            navLinks?.classList.replace('text-white', 'text-brand-dark');
            navDivider?.classList.replace('bg-white/20', 'bg-gray-200');

            navBtn?.classList.replace('border-white', 'border-brand-dark');
            navBtn?.classList.replace('text-white', 'text-brand-dark');
            navBtn?.classList.replace('hover:bg-white', 'hover:bg-brand-dark');
            navBtn?.classList.replace('hover:text-brand-dark', 'hover:text-brand-gold');

            line1?.classList.replace('bg-white', 'bg-brand-dark');
            line3?.classList.replace('bg-white', 'bg-brand-dark');
            
          } else if (e.scroll <= 50 && isScrolled) {
            isScrolled = false;
            header?.classList.replace('bg-white/95', 'bg-transparent');
            header?.classList.replace('border-gray-100', 'border-transparent');
            header?.classList.remove('backdrop-blur-xl', 'shadow-sm');
            header?.classList.replace('py-4', 'py-6');

            logoText?.classList.replace('text-brand-dark', 'text-white');
            navLinks?.classList.replace('text-brand-dark', 'text-white');
            navDivider?.classList.replace('bg-gray-200', 'bg-white/20');

            navBtn?.classList.replace('border-brand-dark', 'border-white');
            navBtn?.classList.replace('text-brand-dark', 'text-white');
            navBtn?.classList.replace('hover:bg-brand-dark', 'hover:bg-white');
            navBtn?.classList.replace('hover:text-brand-gold', 'hover:text-brand-dark');

            line1?.classList.replace('bg-brand-dark', 'bg-white');
            line3?.classList.replace('bg-brand-dark', 'bg-white');
          }
        }
      });
    </script>
  </body>
</html>