---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rozas - Molina & Asociados | Estudio Jurídico Integral">
  
  <section id="inicio" class="relative bg-brand-dark text-white min-h-[90vh] md:min-h-screen flex items-center px-6 md:px-12 overflow-hidden pt-32 md:pt-40 pb-20 md:pb-24">

    <div class="absolute inset-0 z-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"></div>
    <div class="absolute top-1/2 right-0 md:-right-20 w-[30rem] md:w-[50rem] h-[30rem] md:h-[50rem] bg-brand-gold/15 rounded-full blur-[100px] md:blur-[130px] pointer-events-none z-0 -translate-y-1/2"></div>

    <div class="absolute top-0 right-[20%] w-px h-full bg-gradient-to-b from-transparent via-brand-gold/20 to-transparent z-0 hidden lg:block"></div>
    <div class="absolute top-0 right-[35%] w-px h-full bg-gradient-to-b from-transparent via-brand-gold/10 to-transparent z-0 hidden lg:block"></div>

    <div class="container mx-auto max-w-5xl relative z-10 w-full text-center md:text-left flex flex-col md:block items-center">

      <div class="inline-flex items-center gap-4 mb-8 md:mb-10 opacity-90">
        <div class="flex text-brand-gold text-[10px] tracking-widest">
          ★★★★★
        </div>
        <span class="text-gray-400 font-body text-[9px] md:text-[10px] tracking-[0.25em] uppercase border-l border-white/20 pl-4">
          5.0 Excelencia en Google
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[6rem] font-heading font-normal leading-[1.1] md:leading-[1.05] mb-8 text-white tracking-tight">
        La ley exige precisión. <br />
        <span class="italic text-brand-gold font-light">Nosotros, resultados.</span>
      </h1>

      <div class="md:border-l-2 md:border-brand-gold/50 md:pl-8 mb-10 md:mb-12">
        <p class="text-base md:text-xl font-light text-gray-400 max-w-2xl leading-relaxed md:leading-loose">
          Ejercemos la abogacía con visión estratégica y litigante para proteger su patrimonio, su familia y su futuro.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4 md:gap-8 w-full md:w-auto">
        <a href="#contacto" class="inline-flex items-center justify-center bg-brand-gold text-brand-dark px-8 md:px-12 py-4 md:py-5 font-body font-bold uppercase tracking-[0.2em] text-[10px] md:text-[11px] hover:bg-white transition-colors duration-500 w-full sm:w-auto text-center">
          Consulta Inmediata
        </a>
        <a href="#areas" class="inline-flex items-center justify-center gap-4 text-white hover:text-brand-gold transition-colors duration-300 font-body text-[10px] md:text-[11px] uppercase tracking-[0.2em] px-4 py-4 w-full sm:w-auto group">
          <span class="w-8 h-px bg-white/30 group-hover:bg-brand-gold transition-colors hidden sm:block"></span>
          Descubrir Áreas
        </a>
      </div>
    </div>

    <div class="absolute bottom-0 left-6 md:left-12 flex flex-col items-center gap-4 opacity-40 hidden sm:flex">
      <span class="text-[8px] font-body tracking-[0.4em] text-white uppercase" style="writing-mode: vertical-rl;">Scroll</span>
      <div class="w-px h-16 md:h-24 bg-gradient-to-b from-white to-transparent"></div>
    </div>

  </section>

  <section id="areas" class="py-20 md:py-32 bg-brand-light px-6 relative z-10">
    <div class="container mx-auto max-w-5xl">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 md:mb-20 gap-6 md:gap-8">
        <div>
          <span class="text-brand-gold font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 block">Especialidades</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-semibold text-brand-dark tracking-tight leading-tight">Áreas de Práctica.</h2>
        </div>
        <p class="text-base md:text-lg text-gray-500 font-light leading-relaxed md:leading-loose max-w-sm md:text-right">
          Dominio técnico y experiencia probada en las ramas más críticas del derecho.
        </p>
      </div>

      <div class="border-t border-brand-dark/10">
        
        <div class="group flex flex-col md:flex-row items-start md:items-center py-8 md:py-10 border-b border-brand-dark/10 hover:bg-white transition-colors duration-500 md:px-8">
          <div class="w-full md:w-1/4 mb-3 md:mb-0">
            <span class="text-xs md:text-sm font-body font-light text-brand-gold tracking-[0.2em]">01</span>
          </div>
          <div class="w-full md:w-1/3 mb-4 md:mb-0">
            <h3 class="text-2xl md:text-3xl font-heading font-medium text-brand-dark group-hover:text-brand-gold transition-colors leading-tight">Familia & <br class="hidden md:block"/> Sucesiones</h3>
          </div>
          <div class="w-full md:w-5/12">
            <ul class="space-y-3 text-sm font-light text-gray-600 leading-relaxed">
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Sucesiones ab intestato y testamentarias</span></li>
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Divorcios de mutuo acuerdo y contradictorios</span></li>
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Fijación y reclamo de Cuota Alimentaria</span></li>
            </ul>
          </div>
        </div>

        <div class="group flex flex-col md:flex-row items-start md:items-center py-8 md:py-10 border-b border-brand-dark/10 hover:bg-white transition-colors duration-500 md:px-8">
          <div class="w-full md:w-1/4 mb-3 md:mb-0">
            <span class="text-xs md:text-sm font-body font-light text-brand-gold tracking-[0.2em]">02</span>
          </div>
          <div class="w-full md:w-1/3 mb-4 md:mb-0">
            <h3 class="text-2xl md:text-3xl font-heading font-medium text-brand-dark group-hover:text-brand-gold transition-colors leading-tight">Penal & <br class="hidden md:block"/> Civil</h3>
          </div>
          <div class="w-full md:w-5/12">
            <ul class="space-y-3 text-sm font-light text-gray-600 leading-relaxed">
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Defensas Penales y asistencia integral</span></li>
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Redacción y ejecución de Contratos</span></li>
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Reclamos por Accidentes de Tránsito</span></li>
            </ul>
          </div>
        </div>

        <div class="group flex flex-col md:flex-row items-start md:items-center py-8 md:py-10 border-b border-brand-dark/10 hover:bg-white transition-colors duration-500 md:px-8">
          <div class="w-full md:w-1/4 mb-3 md:mb-0">
            <span class="text-xs md:text-sm font-body font-light text-brand-gold tracking-[0.2em]">03</span>
          </div>
          <div class="w-full md:w-1/3 mb-4 md:mb-0">
            <h3 class="text-2xl md:text-3xl font-heading font-medium text-brand-dark group-hover:text-brand-gold transition-colors leading-tight">Laboral & <br class="hidden md:block"/> Riesgos</h3>
          </div>
          <div class="w-full md:w-5/12">
            <ul class="space-y-3 text-sm font-light text-gray-600 leading-relaxed">
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Reclamos por Despidos (Con o sin causa)</span></li>
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Accidentes de Trabajo y reclamos ART</span></li>
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Trabajo no registrado y diferencias salariales</span></li>
            </ul>
          </div>
        </div>

        <div class="group flex flex-col md:flex-row items-start md:items-center py-8 md:py-10 hover:bg-white transition-colors duration-500 md:px-8">
          <div class="w-full md:w-1/4 mb-3 md:mb-0">
            <span class="text-xs md:text-sm font-body font-light text-brand-gold tracking-[0.2em]">04</span>
          </div>
          <div class="w-full md:w-1/3 mb-4 md:mb-0">
            <h3 class="text-2xl md:text-3xl font-heading font-medium text-brand-dark group-hover:text-brand-gold transition-colors leading-tight">Previsional & <br class="hidden md:block"/> Tributario</h3>
          </div>
          <div class="w-full md:w-5/12">
            <ul class="space-y-3 text-sm font-light text-gray-600 leading-relaxed">
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Tramitación de Jubilaciones y Pensiones</span></li>
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Asesoramiento Tributario e Impositivo</span></li>
              <li class="flex items-start"><span class="text-brand-gold mr-3 mt-0.5">/</span> <span>Defensas ante organismos de recaudación</span></li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section id="estudio" class="py-20 md:py-32 bg-brand-dark text-white px-6 relative overflow-hidden border-y border-white/5">
    
    <div class="absolute inset-0 z-0 opacity-5" style="background-image: radial-gradient(#c5a47e 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="container mx-auto max-w-4xl text-center relative z-10">
      
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.5" stroke="currentColor" class="w-12 h-12 md:w-16 md:h-16 text-brand-gold mx-auto mb-6 md:mb-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" />
      </svg>
      
      <span class="text-brand-gold font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 md:mb-6 block">Nuestro Estudio</span>
      
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-medium text-white leading-[1.2] mb-6 md:mb-8">
        En Rozas & Molina brindamos asesoramiento jurídico integral con un enfoque <span class="italic text-brand-gold font-light">estratégico y personalizado.</span>
      </h2>
      
      <p class="text-base md:text-lg font-light text-gray-400 leading-relaxed md:leading-loose max-w-2xl mx-auto">
        Nuestro compromiso es acompañar a cada cliente con seriedad, confidencialidad y excelencia profesional.
      </p>
      
    </div>
  </section>

  <section class="py-20 md:py-32 bg-white px-6 relative z-10">
    <div class="container mx-auto max-w-6xl">
      
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-10 mb-16 md:mb-24">
        
        <div class="w-full lg:w-3/5">
          <span class="text-brand-gold font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 md:mb-6 block">Reputación Intachable</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-semibold text-brand-dark leading-[1.1] tracking-tight">
            Compromiso absoluto. <br/>
            <span class="font-light italic text-brand-gold">Resultados comprobables.</span>
          </h2>
        </div>

        <div class="w-full lg:w-2/5 flex lg:justify-end">
          <a href="https://maps.google.com/?cid=ChIJ09W7OwDVvJURPp23GLTtKJA" target="_blank" class="group flex items-center gap-5 md:gap-6 p-6 md:p-8 bg-brand-light border border-gray-100 hover:border-brand-gold/50 hover:bg-white transition-all duration-500 shadow-xl shadow-brand-dark/5 w-full md:w-auto relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-brand-gold transform origin-bottom scale-y-100 group-hover:scale-y-0 transition-transform duration-500"></div>
            <div class="absolute bottom-0 left-0 w-1.5 h-full bg-brand-dark transform origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-500"></div>
            
            <div class="text-4xl md:text-6xl font-heading font-bold text-brand-dark tracking-tighter">
              5.0
            </div>
            <div class="flex flex-col justify-center">
              <div class="flex text-brand-gold text-[10px] md:text-[12px] tracking-[0.15em] mb-1 md:mb-1.5">
                ★★★★★
              </div>
              <span class="text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-brand-dark font-semibold">Calificación Perfecta</span>
              <span class="text-[10px] md:text-[11px] font-light text-gray-500 mt-0.5">Basado en 16 reseñas de Google</span>
            </div>
          </a>
        </div>

      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 border-y border-gray-200 divide-y md:divide-y-0 md:divide-x divide-gray-200">
        
        <div class="py-10 md:p-12 hover:bg-brand-light transition-colors duration-500 group">
          <div class="text-3xl md:text-4xl font-heading font-light text-brand-gold/30 mb-4 md:mb-6 group-hover:text-brand-gold transition-colors duration-500">01</div>
          <h3 class="font-heading font-semibold text-xl md:text-2xl text-brand-dark mb-3 md:mb-4">Ética y <br class="hidden md:block"/>Transparencia</h3>
          <p class="font-light text-gray-500 text-sm md:text-base leading-relaxed md:leading-loose">
            Hablamos con la verdad. Evaluamos la viabilidad real de su caso y establecemos honorarios claros desde el día uno, sin costos ocultos.
          </p>
        </div>

        <div class="py-10 md:p-12 hover:bg-brand-light transition-colors duration-500 group">
          <div class="text-3xl md:text-4xl font-heading font-light text-brand-gold/30 mb-4 md:mb-6 group-hover:text-brand-gold transition-colors duration-500">02</div>
          <h3 class="font-heading font-semibold text-xl md:text-2xl text-brand-dark mb-3 md:mb-4">Estrategia <br class="hidden md:block"/>Litigante</h3>
          <p class="font-light text-gray-500 text-sm md:text-base leading-relaxed md:leading-loose">
            No improvisamos. Diseñamos tácticas procesales agresivas enfocadas en la resolución rápida, minimizando su desgaste emocional y financiero.
          </p>
        </div>

        <div class="py-10 md:p-12 hover:bg-brand-light transition-colors duration-500 group">
          <div class="text-3xl md:text-4xl font-heading font-light text-brand-gold/30 mb-4 md:mb-6 group-hover:text-brand-gold transition-colors duration-500">03</div>
          <h3 class="font-heading font-semibold text-xl md:text-2xl text-brand-dark mb-3 md:mb-4">Atención <br class="hidden md:block"/>Personalizada</h3>
          <p class="font-light text-gray-500 text-sm md:text-base leading-relaxed md:leading-loose">
            Información clara y constante sobre el estado de su causa. Siempre sabrá en qué instancia se encuentra su expediente, directo de sus abogados.
          </p>
        </div>

      </div>

    </div>
  </section>

  <section id="contacto" class="py-20 md:py-32 bg-[#111216] text-white px-6 border-t border-gray-100">
    <div class="container mx-auto max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-20 items-center">
        
        <div class="lg:col-span-7">
          <span class="text-brand-gold font-body font-medium tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 md:mb-6 block">Solicitar Consulta</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-semibold mb-6 tracking-tight leading-[1.1]">
            No deje sus derechos <br/> <span class="italic font-light text-brand-gold">librados al azar.</span>
          </h2>
          <p class="text-base md:text-lg text-gray-400 font-light mb-8 md:mb-10 leading-relaxed md:leading-loose max-w-lg">
            Complete el formulario con una breve descripción de su situación, o si lo prefiere, comuníquese directamente a nuestra línea de atención rápida.
          </p>
          
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 border-t border-white/10 pt-8">
            <a href="https://wa.me/5491100000000" target="_blank" class="inline-flex items-center gap-4 md:gap-5 group">
              <div class="w-12 h-12 md:w-14 md:h-14 rounded-full border border-white/10 flex items-center justify-center text-brand-gold group-hover:bg-brand-gold group-hover:text-brand-dark transition-all duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-whatsapp md:w-[22px] md:h-[22px]" viewBox="0 0 16 16"><path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/></svg>
              </div>
              <div class="flex flex-col">
                <span class="font-body text-[9px] md:text-[10px] tracking-[0.2em] uppercase text-gray-500 mb-0.5 md:mb-1">Línea Directa</span>
                <span class="font-medium text-white group-hover:text-brand-gold transition-colors text-base md:text-lg tracking-wide">+54 9 11 0000-0000</span>
              </div>
            </a>
          </div>
        </div>

        <div class="lg:col-span-5 w-full">
          <div class="bg-brand-dark p-6 md:p-10 border border-white/5 shadow-2xl shadow-black/50 relative">
            <div class="absolute top-0 left-0 w-full h-1 bg-brand-gold/80"></div>
            
            <form action="#" method="POST" class="space-y-6 md:space-y-8 mt-2">
              <div class="relative group">
                <label for="nombre" class="block text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-gray-500 group-focus-within:text-brand-gold mb-2 transition-colors">Nombre completo</label>
                <input type="text" id="nombre" name="nombre" placeholder="Ej. Juan Pérez" class="w-full bg-transparent border-b border-white/10 pb-2 md:pb-3 text-white text-sm md:text-base focus:outline-none focus:border-brand-gold transition-colors font-light placeholder:text-gray-700" required>
              </div>
              
              <div class="relative group">
                <label for="telefono" class="block text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-gray-500 group-focus-within:text-brand-gold mb-2 transition-colors">Teléfono</label>
                <input type="tel" id="telefono" name="telefono" placeholder="Ej. 11 1234 5678" class="w-full bg-transparent border-b border-white/10 pb-2 md:pb-3 text-white text-sm md:text-base focus:outline-none focus:border-brand-gold transition-colors font-light placeholder:text-gray-700" required>
              </div>
              
              <div class="relative group">
                <label for="consulta" class="block text-[9px] md:text-[10px] font-body tracking-[0.2em] uppercase text-gray-500 group-focus-within:text-brand-gold mb-2 transition-colors">Consulta breve</label>
                <textarea id="consulta" name="consulta" rows="3" placeholder="Describa brevemente su caso..." class="w-full bg-transparent border-b border-white/10 pb-2 md:pb-3 text-white text-sm md:text-base focus:outline-none focus:border-brand-gold transition-colors font-light resize-none placeholder:text-gray-700" required></textarea>
              </div>
              
              <button type="submit" class="w-full bg-brand-gold text-brand-dark py-4 font-body font-bold uppercase tracking-[0.2em] text-[10px] md:text-[11px] hover:bg-white transition-all duration-500 mt-2">
                Enviar consulta
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>